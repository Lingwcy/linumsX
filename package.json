{
  "name": "linumsx",
  "version": "1.0.0",
  "description": "linumsX AI-powered Word document agent",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "linumsx": "dist/application/cli/index.js",
    "agent-doc": "dist/application/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsc && node ./dist/application/cli/index.js ink",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@xmldom/xmldom": "^0.8.11",
    "adm-zip": "^0.5.16",
    "commander": "^12.0.0",
    "docx": "^8.5.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
